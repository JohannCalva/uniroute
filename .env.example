POSTGRES_USER=uniroute
POSTGRES_PASSWORD=uniroute_dev_password
POSTGRES_DB=uniroute
DATABASE_URL=postgresql://uniroute:uniroute_dev_password@postgres:5432/uniroute
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
JWT_SECRET=dev_jwt_secret_change_in_production
QR_HMAC_SECRET=dev_qr_hmac_secret_change_in_production

# Puerto host para nginx. Cambialo si el 80 ya está ocupado en tu máquina
# (p.ej. IIS en Windows). No afecta al resto del stack.
NGINX_PORT=80
# Puerto host para HTTPS/TLS (nginx escucha en 443 dentro del contenedor).
NGINX_HTTPS_PORT=443
